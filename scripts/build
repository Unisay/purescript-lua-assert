#!/usr/bin/env bash
set -euo pipefail

echo "Building..."

# pslua writes --lua-output-file dist/Test.Assert.lua with withFile WriteMode,
# which does not create parent directories. dist/ is absent on a fresh checkout,
# so ensure it exists before the pslua invocation below.
mkdir -p dist

spago build --quiet

pslua --foreign-path . --ps-output output --entry Test.Assert --lua-output-file dist/Test.Assert.lua
